{
  "mcpServers": {
    "context7": {
      "command": "$HOME/.local/share/mise/installs/node/$NODE_VERSION/bin/npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "PATH": "$HOME/.local/share/mise/installs/node/$NODE_VERSION/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    "chrome-devtools": {
      "command": "$HOME/.local/share/mise/installs/node/$NODE_VERSION/bin/npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "env": {
        "PATH": "$HOME/.local/share/mise/installs/node/$NODE_VERSION/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    "playwright": {
      "command": "$HOME/.local/share/mise/installs/node/$NODE_VERSION/bin/npx",
      "args": ["@playwright/mcp@latest"],
      "env": {
        "PATH": "$HOME/.local/share/mise/installs/node/$NODE_VERSION/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  }
}
